# === BẢO MẬT ===
# Tạo key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === DATABASE ===
DATABASE_URL=sqlite:///./sql_app.db

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173

# === ADMIN ===
ADMIN_DEFAULT_PASSWORD=

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_DOMAINS=smartland.vn,smartrealtors.vn

# === AI ===
AI_PROVIDER=auto
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# === GIÁ TRỊ ĐƠN HÀNG TRUNG BÌNH (VNĐ) ===
AVG_ORDER_VALUE=50000000

# === UPLOAD ===
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads
